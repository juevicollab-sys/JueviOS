# Ju&Vi Studio OS — normalização de fim de linha
# Impede que arquivos apareçam como "totalmente modificados" quando o editor
# converte LF<->CRLF no Windows. O repositório guarda tudo em LF.

# Padrão: detectar arquivos de texto e normalizar para LF no commit.
* text=auto eol=lf

# Código e configuração — sempre LF
*.dart   text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.json   text eol=lf
*.sql    text eol=lf
*.md     text eol=lf
*.html   text eol=lf
*.css    text eol=lf
*.js     text eol=lf
*.txt    text eol=lf
*.xml    text eol=lf
*.cmake  text eol=lf
*.cpp    text eol=lf
*.h      text eol=lf
*.cc     text eol=lf
*.gradle text eol=lf
*.kt     text eol=lf
*.properties text eol=lf
.gitignore   text eol=lf
.gitattributes text eol=lf

# Scripts específicos de plataforma mantêm o fim de linha nativo
*.bat    text eol=crlf
*.cmd    text eol=crlf
*.ps1    text eol=crlf
*.sh     text eol=lf

# Binários — nunca normalizar nem fazer diff de texto
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.svg    binary
*.ico    binary
*.pdf    binary
*.docx   binary
*.ttf    binary
*.otf    binary
*.woff   binary
*.woff2  binary
*.zip    binary
*.jar    binary
*.keystore binary
*.apk    binary
*.aab    binary
