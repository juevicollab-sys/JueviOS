# JueviOS — Template de variáveis de ambiente
# Copie para .env e preencha. NUNCA comite o .env (está no .gitignore).

# Supabase (obrigatório para dados reais; sem isto o app roda em modo demo)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...

# Notion (opcional — sync via n8n)
NOTION_TOKEN=secret_xxx
NOTION_PROJECTS_DB=xxx
NOTION_CONTACTS_DB=xxx
NOTION_FINANCES_DB=xxx

# n8n webhook (opcional)
N8N_NOTION_SYNC_WEBHOOK=http://localhost:5678/webhook/xxx
